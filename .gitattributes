# Force LF line endings for all text files in the repository.
# This prevents CRLF on Windows from breaking shell scripts and
# GitHub Actions workflow files on Linux runners.
* text=auto eol=lf

# Explicitly mark binary files so git never touches their line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.gz   binary
*.tar  binary
